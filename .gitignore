# =============================================================================
# tax-buddy — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.eggs/
lib/
lib64/
MANIFEST

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak
.venv.bak

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets.json
credentials.json

# ── Uploaded / processed tax documents ───────────────────────────────────────
backend/data/uploads/
backend/data/processed/
backend/data/outputs/
*.pdf
*.tiff
*.tif

# ── ML model weights & caches ────────────────────────────────────────────────
*.pt
*.pth
*.bin
*.onnx
*.pkl
*.pickle
ner_checkpoints/
ml/ner/checkpoints/
ml/ocr/checkpoints/
.paddlex/
~/.paddlex/

# HuggingFace / transformers cache
.cache/
transformers_cache/
hf_cache/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/

# ── Type checking ────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs & editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
*.sublime-project
*.sublime-workspace

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ── Node (if any frontend tooling is added) ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ───────────────────────────────────────────────────────────────────
*.dockerignore

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.hypothesis/
