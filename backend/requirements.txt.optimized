# ============================================================================
# tax-buddy backend — Production dependencies (OPTIMIZED)
# Pinned versions for reproducibility across environments
# 
# CHANGES FROM ORIGINAL:
# - REMOVED: python-dotenv (redundant with pydantic-settings v2+)
# - KEPT: pandas, requests (pending verification - may be transitive deps)
# - ENHANCED: Added usage notes for clarity
# ============================================================================

# ── Web Framework ────────────────────────────────────────────────────────────
fastapi==0.136.1                # Core web framework (main.py, routes.py)
uvicorn[standard]==0.46.0       # ASGI server with performance extras
uvloop==0.22.1                  # High-performance event loop (uvicorn dependency)
python-multipart==0.0.26        # File upload handling (UploadFile support)

# ── Configuration & Validation ───────────────────────────────────────────────
pydantic==2.13.3                # Data validation (schemas.py, config.py)
pydantic-settings==2.14.0       # Settings management with built-in .env support
# REMOVED: python-dotenv==1.2.2 (pydantic-settings v2+ handles .env natively)

# ── Database ─────────────────────────────────────────────────────────────────
SQLAlchemy==2.0.49              # ORM for SQLite operations (database.py)

# ── OCR Pipeline ─────────────────────────────────────────────────────────────
opencv-python-headless==4.13.0.92  # Image preprocessing (ocr_service.py, preprocess.py)
pytesseract==0.3.13             # Tesseract OCR wrapper (fallback engine)
paddleocr==3.5.0                # Primary OCR engine with high accuracy
# Note: paddlepaddle is required by paddleocr but has no ARM64 wheel for macOS
# On x86_64 Linux/Windows, install with: pip install paddlepaddle
# On ARM64 macOS, PaddleOCR will gracefully fall back to Tesseract
pdf2image==1.17.0               # PDF to image conversion (preprocess.py)
pdfplumber==0.11.4              # Direct PDF text extraction (ocr_service.py)
PyMuPDF==1.25.5                 # Alternative PDF extraction via fitz (ocr_service.py)

# ── NLP / Named Entity Recognition ───────────────────────────────────────────
transformers==5.6.2             # Hugging Face transformers (optional NER in ner_service.py)
torch==2.11.0                   # PyTorch ML framework (required by transformers)
tokenizers==0.22.2              # Fast tokenization (transformers dependency)

# ── Data Processing ──────────────────────────────────────────────────────────
pandas==3.0.2                   # Data manipulation (VERIFY: not directly imported, may be transitive)
numpy==2.3.5                    # Numerical operations (ocr_service.py for confidence calculations)

# ── PDF Generation & Reporting ───────────────────────────────────────────────
reportlab==4.4.10               # PDF report generation (routes.py /generate-report endpoint)

# ── Utilities ────────────────────────────────────────────────────────────────
requests==2.33.1                # HTTP client (VERIFY: not directly imported, likely transitive)
Pillow==12.2.0                  # Image handling (required by pdf2image and OCR libraries)

# ── AI / LLM ─────────────────────────────────────────────────────────────────
groq==1.2.0                     # Groq API client for AI features (groq_service.py, ai_validation_service.py, tax_optimization_service.py)

# ============================================================================
# INSTALLATION NOTES
# ============================================================================
# 
# Standard installation:
#   pip install -r requirements.txt
# 
# For ARM64 macOS (Apple Silicon):
#   - PaddleOCR will use Tesseract fallback (no paddlepaddle wheel available)
#   - All other packages install normally
# 
# For x86_64 Linux/Windows with PaddleOCR:
#   pip install -r requirements.txt
#   pip install paddlepaddle  # Additional step for full PaddleOCR support
# 
# Development installation:
#   pip install -r requirements.txt
#   pip install pytest pytest-cov black flake8  # Dev tools
# 
